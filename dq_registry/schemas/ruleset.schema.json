{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "dataset_id",
    "ruleset_version",
    "rules"
  ],
  "properties": {
    "dataset_id": {
      "type": "string"
    },
    "ruleset_version": {
      "type": "integer"
    },
    "owner_team": {
      "type": "string"
    },
    "data_owner": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "rule_type",
          "severity",
          "expectation"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "rule_type": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "expectation": {
            "type": "object"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "rule_type": {
                  "const": "schema"
                }
              }
            },
            "then": {
              "properties": {
                "expectation": {
                  "type": "object",
                  "required": [
                    "required_columns"
                  ],
                  "properties": {
                    "required_columns": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "minItems": 1
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "rule_type": {
                  "enum": [
                    "completeness",
                    "uniqueness",
                    "domain",
                    "range",
                    "date_not_in_future",
                    "anomaly_detection"
                  ]
                }
              }
            },
            "then": {
              "properties": {
                "expectation": {
                  "type": "object",
                  "required": [
                    "column"
                  ],
                  "properties": {
                    "column": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "rule_type": {
                  "const": "domain"
                }
              }
            },
            "then": {
              "properties": {
                "expectation": {
                  "type": "object",
                  "required": [
                    "allowed_values"
                  ],
                  "properties": {
                    "allowed_values": {
                      "type": "array",
                      "minItems": 1
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "rule_type": {
                  "const": "range"
                }
              }
            },
            "then": {
              "properties": {
                "expectation": {
                  "type": "object",
                  "anyOf": [
                    {
                      "required": [
                        "min"
                      ]
                    },
                    {
                      "required": [
                        "max"
                      ]
                    }
                  ]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "rule_type": {
                  "const": "anomaly_detection"
                }
              }
            },
            "then": {
              "properties": {
                "expectation": {
                  "type": "object",
                  "required": [
                    "column",
                    "method"
                  ],
                  "properties": {
                    "column": {
                      "type": "string",
                      "minLength": 1
                    },
                    "method": {
                      "type": "string",
                      "enum": [
                        "non_negative",
                        "zscore",
                        "iqr"
                      ]
                    },
                    "threshold": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    "direction": {
                      "type": "string",
                      "enum": [
                        "low",
                        "high",
                        "both"
                      ]
                    },
                    "min_hard": {
                      "type": "number"
                    },
                    "max_hard": {
                      "type": "number"
                    },
                    "window_hint": {
                      "type": "string"
                    }
                  },
                  "allOf": [
                    {
                      "if": {
                        "properties": {
                          "method": {
                            "enum": [
                              "zscore",
                              "iqr"
                            ]
                          }
                        }
                      },
                      "then": {
                        "required": [
                          "threshold"
                        ]
                      }
                    }
                  ]
                }
              }
            }
          }
        ]
      }
    }
  }
}
