{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "dataset_id",
    "ruleset_version",
    "rules"
  ],
  "properties": {
    "dataset_id": {
      "type": "string"
    },
    "ruleset_version": {
      "type": "integer"
    },
    "owner_team": {
      "type": "string"
    },
    "data_owner": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "rule_type",
          "severity",
          "expectation"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "rule_type": {
            "type": "string",
            "enum": [
              "schema",
              "completeness",
              "uniqueness",
              "range",
              "domain",
              "date_not_in_future",
              "freshness",
              "referential_integrity",
              "etl_validation"
            ]
          },
          "severity": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean",
            "description": "When false, the rule is skipped during execution. Defaults to true when omitted."
          },
          "description": {
            "type": "string"
          },
          "suggested_by": {
            "type": "string"
          },
          "ai_confidence": {
            "type": "number"
          },
          "ai_rationale": {
            "type": "string"
          },
          "expectation": {
            "type": "object",
            "properties": {
              "sql_ref": {
                "type": "array",
                "description": "Required for etl_validation rules. Each item is a file reference or an inline SQL block.",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "oneOf": [
                    {
                      "required": ["file"],
                      "properties": {
                        "file": {
                          "type": "string",
                          "description": "Relative path to a .sql file."
                        }
                      },
                      "additionalProperties": false
                    },
                    {
                      "required": ["inline_sql"],
                      "properties": {
                        "inline_sql": {
                          "type": "string",
                          "description": "Inline SQL text."
                        }
                      },
                      "additionalProperties": false
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
