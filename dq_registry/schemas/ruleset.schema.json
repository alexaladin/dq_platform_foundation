{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "dataset_id",
    "ruleset_version",
    "rules"
  ],
  "properties": {
    "dataset_id": {
      "type": "string"
    },
    "ruleset_version": {
      "type": "integer"
    },
    "owner_team": {
      "type": "string"
    },
    "data_owner": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "rule_type",
          "severity",
          "expectation"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "rule_type": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "expectation": {
            "type": "object"
          }
        }
      }
    }
  }
}
